# Copy this to `.streamlit/secrets.toml` for local Postgres testing, OR paste
# the same key into Streamlit Community Cloud → app → Settings → Secrets.
#
# Local dev needs NO secrets at all — without DATABASE_URL the app uses a local
# SQLite file (bach_bash.db). Set DATABASE_URL only when you want durable,
# hosted storage (e.g. a free Neon Postgres database).

# DATABASE_URL = "postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
